nResultT]], AbstractAsyncContextManager[LifespanResultT]]:\n    @asynccontextmanager\n    async def wrap(_: Server[LifespanResultT]) -> AsyncIterator[LifespanResultT]:\n        async with lifespan(app) as context:\n            yield context\n\n    return wrap\n\n\nclass MCPServer(Generic[LifespanResultT]):", "numLines": 50, "startLine": 80, "totalLines": 1113}}, "tool_use_id": "toolu_015pQ9bRDxtxuAYpbAWszJCJ"}
