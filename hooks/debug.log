Count = 0;\n    } else if (encCount <= -STEPS_PER_DETENT) {\n      uint8_t dn[3] = {KEY_DOWN_ARROW, 0, 0};\n      Keyboard.sendCombo(dn);\n      Keyboard.releaseAll();\n      encCount = 0;\n    }\n  }", "replace_all": false}, "tool_use_id": "toolu_01AJqjtxdU7mxa5DKvwyXWdk"}
