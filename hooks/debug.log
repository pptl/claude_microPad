 Win+Tab\n  {KEY_ESC,        0,             0}  // GP9: ESC\n};", "newString": "//for test\nconst uint8_t BTN_KEYS[10][3] = {\n  {HID_KEY_0, 0, 0}, // GP0: 0\n  {HID_KEY_1, 0, 0}, // GP1: 1\n  {HID_KEY_2, 0, 0}, // GP2: 2\n  {HID_KEY_3, 0, 0}, // GP3: 3\n  {HID_KEY_4, 0, 0}, // GP4: 4\n  {HID_KEY_5, 0, 0}, // GP5: 5\n  {HID_KEY_6, 0, 0}, // GP6: 6\n  {HID_KEY_7, 0, 0}, // GP7: 7\n  {HID_KEY_8, 0, 0}, // GP8: 8\n  {HID_KEY_9, 0, 0}, // GP9: 9\n};", "originalFile": "/*\n  Claude Ghost Macro Pad V1.0 \n  \udce9\udc81\u62cd\udc94\u51bd\udc96\udcbc YD-RP2040 (IDE \u95ae\u5256\udcae\udc9a\u96a2\udc8b\udce9\udc81\udcb8 Raspberry Pi Pico)\n*/\n\n#include <Adafruit_TinyUSB.h>\n\n// --- 1. \u7488\udc8b\udce6\udc8e\u4ea4\udc8c\udc89\udce9\udc8d\u8404\udcae\udc9a\u8762\udca9 (\u64a0\udc87\udce8\udc88\udc8a\u969e\udca3\u8763\u6f78\udcbd\udc89\udce5\udc90\udc91 TinyUSB) ---\n#define KEY_LEFT_CTRL   HID_KEY_CONTROL_LEFT\n#define KEY_LEFT_SHIFT  HID_KEY_SHIFT_LEFT\n#define KEY_LEFT_GUI    HID_KEY_GUI_LEFT\n#define KEY_LEFT_ALT    HID_KEY_ALT_LEFT\n#define KEY_UP_ARROW    HID_KEY_ARROW_UP\n#define KEY_DOWN_ARROW  HID_KEY_ARROW_DOWN\n#define KEY_RETURN      HID_KEY_RETURN\n#define KEY_ESC         HID_KEY_ESCAPE\n#define KEY_TAB         HID_KEY_TAB\n\n// --- 2. \udce6\udc89\udc8b\udce5\udc8b\udc95\u64b1\u7b87\udcab\udc8b Keyboard \u7485\u22a5\udc93\u7949\udc89\u62d0\u8fa3 ---\nuint8_t const desc_hid_report[] = { TUD_HID_REPORT_DESC_KEYBOARD() };\nAdafruit_USBD_HID usb_hid;\n\nclass KeyboardEmulator {\npublic:\n  void begin() {\n    usb_hid.setPollInterval(2);\n    usb_hid.setReportDescriptor(desc_hid_report, sizeof(desc_hid_report));\n    usb_hid.begin();\n  }\n\n  // \u929d\udc80\u7508\u22bf\udc80\udc81\udce5\udc87\u7bb8\udc9c\udc80\u61ad\udc9a 3 \udce5\udc80\udc8b\udce6\udc8c\udc89\udce9\udc8d\u8407\udc9a\udc84\u6470\udc8c\udce6\udc95\u6e21\udcb5\udc84\udce5\udc90\udc88\udce5\udca0\u52d7\udc91\udc8a\u5697\udc88\udce5\udc90\udc8c\udce6\udc99\udc82\udce8\udc99\udc95\udce7\udc90\udc86 modifier + \u929d\udc80\udce8\udc88\u7947\udc8d\u86db\udcbc\udc89\n  void sendCombo(const uint8_t keys[3]) {\n    if (!usb_hid.ready()) return;\n    uint8_t mod = 0;\n    uint8_t keycodes[6] = {0};\n    int ki = 0;\n    for (int k = 0; k < 3; k++) {\n      if (keys[k] == 0) continue;\n      if (keys[k] >= 0xE0 && keys[k] <= 0xE7) {\n        mod |= (1 << (keys[k] - 0xE0));  // modifier key\n      } else {\n        if (ki < 6) keycodes[ki++] = keys[k];\n      }\n    }\n    usb_hid.keyboardReport(0, mod, keycodes);\n  }\n\n  // \u8751\udc89\u657a\udc85 USB \u8761\u822b\udcbb\udc9e\u64a0\u6881\udcb7\udc92\u657a\udc8c\udce5\udc86\udc8d\udce9\udc80\udc81\udce9\udc87\udc8b\udce6\udc94\u66c9\udca0\u52d7\udc91\udc8a\u5697\udc8c\u8763\u7b94\udcbf\udc9d\u929d\u9905\udca9\udc9f\udce8\udc83\u8ce3\udc94\u55c5\udc88\udcb0 key-up\n  void releaseAll() {\n    unsigned long t = millis();\n    while (!usb_hid.ready() && (millis() - t) < 20) delay(1);\n    usb_hid.keyboardRelease(0);\n  }\n} Keyboard;\n\n// --- 3. \u8756\u7947\udcab\udc94\udce8\udc85\u5583\udcbd\udc8d\u6470\udc9a\u8762\udca9 ---\nconst int LED_PINS[6] = {2, 3, 4, 28, 27, 26}; // R1 G1 B1 R2 G2 B2\nconst int BTN_PINS[10] = {6, 7, 16, 17, 8, 9, 19, 18, 0, 22};\nconst int ENC_CLK = 10;\nconst int ENC_DT  = 11;\n\n//for test\nconst uint8_t BTN_KEYS[10][3] = {\n  {1,  0,           0}, // GP0: Ctrl+C\n  {2, 0,       0}, // GP1: Shift+Tab\n  {KEY_LEFT_CTRL,  'e',           0}, // GP2: Ctrl+E\n  {KEY_UP_ARROW,   0,             0}, // GP3: Up\n  {KEY_RETURN,     0,             0}, // GP4: Enter\n  {KEY_LEFT_CTRL,  't',           0}, // GP5: Ctrl+T\n  {HID_KEY_SLASH,  0,             0}, // GP6: /\n  {KEY_DOWN_ARROW, 0,             0}, // GP7: Down\n  {KEY_LEFT_GUI,   KEY_TAB,       0}, // GP8: Win+Tab\n  {KEY_ESC,        0,             0}  // GP9: ESC\n};\n/* const uint8_t BTN_KEYS[10][3] = {\n  {KEY_LEFT_CTRL,  'c',           0}, // GP0: Ctrl+C\n  {KEY_LEFT_SHIFT, KEY_TAB,       0}, // GP1: Shift+Tab\n  {KEY_LEFT_CTRL,  'e',           0}, // GP2: Ctrl+E\n  {KEY_UP_ARROW,   0,             0}, // GP3: Up\n  {KEY_RETURN,     0,             0}, // GP4: Enter\n  {KEY_LEFT_CTRL,  't',           0}, // GP5: Ctrl+T\n  {HID_KEY_SLASH,  0,             0}, // GP6: /\n  {KEY_DOWN_ARROW, 0,             0}, // GP7: Down\n  {KEY_LEFT_GUI,   KEY_TAB,       0}, // GP8: Win+Tab\n  {KEY_ESC,        0,             0}  // GP9: ESC\n};\n */\n// --- 4. Debounce \udce7\udc8b\udc80\udce6\udc85\udc8b ---\nconst unsigned long DEBOUNCE_MS = 20;\n\nbool rawBtn[10];       // \udce7\udc9b\u6840\udc89\udc8d\u9708\udc80\udce5\udc88\u5541\udc9a\udc84\udce5\udc8e\udc9f\u61aa\udc8b\udce9\udc9b\u98b1\udcbd\udc8d\nbool stableBtn[10];    // \u876c\udc93\udce9\udc81\udc8e debounce \u657a\udc8c\udce7\udc9a\udc84\u875b\u62d9\udcae\udc9a\udce7\udc8b\udc80\udce6\udc85\udc8b\nunsigned long debounceTimer[10];\n\n// \udce6\udc97\udc8b\udce9\udc88\udc95 - \u7507\udca3\u922d\u65a4\udc8b\udc80\udce6\udc85\udc8b\u7488\udc9f + \u875b\u62d9\udcae\udc9a\udce6\udc99\udc82\udce9\udc96\udc93 debounce\n// \udce6\udc96\u5541\udc8b\udc80\udce6\udc85\udc8b\u6579\udc85\udce9\udca0\udc88\u977d\udc9d\udce6\udc8c\udc81\u875b\u62d9\udcae\udc9a ENC_STABLE_MS \u7625\u600e\udca7\udc92\udce6\udc89\udc8d\u875e\udc97\udce6\udc9c\udc89\udce6\udc95\udc88\u9827\udc89\udce6\udc8f\udc9b\u5697\udc8c\udce9\udc98\u812b\u8feb\u6576\udc88\u981d\u559f\u655e\u875b\udc8d\nuint8_t encState   = 0;  // \udce6\udc9c\udc80\u657a\udc8c\u8763\u7b84\udcaa\udc8d\udce7\udc9a\udc84\u875b\u62d9\udcae\udc9a\udce7\udc8b\udc80\udce6\udc85\udc8b\nuint8_t encPending = 0;  // \udce7\udc9b\u6840\udc89\udc8d\u9708\udc80\udce5\udc88\u555c\udc80\udc81\u64a0\udc9a\u657a\udc85\u8763\u7b84\udcaa\udc8d\udce7\udc9a\udc84\udce7\udc8b\udc80\udce6\udc85\udc8b\nint8_t  encCount   = 0;\nunsigned long encStableTimer = 0;\nconst unsigned long ENC_STABLE_MS  = 5;  // \u977d\u221f\udc99\udc9f\u875b\u62d9\udcae\udc9a\udce9\udc96\udc80\u747c\u9cf4\udcbc\udc88\u7625\u600e\udca7\udc92\u5697\udc89\nconst int8_t        STEPS_PER_DETENT = 4; // EC11 \u7485\udc99\u769e\udc96\udce5\udc80\u6f58\udcbc\udc9b\udce8\udc8b\u4e69\udcb8\udc80\udce6\udca0\u6f78\u5b5b\udce7\udc99\u6f86\udc85\u62c7\u6d3b\udce6\udc94\u5bde\udc88\udc90 2\n\n// \u7507\udca3\u922d\u65b9\u573e\u8763\u6f78\u201d\u5697\udc9aENC_TABLE[\udce8\udc88\udc8a\udce7\udc8b\udc80\udce6\udc85\udc8b][\udce6\udc96\u5541\udc8b\udc80\udce6\udc85\udc8b] = +1 (CW) / -1 (CCW) / 0 (\udce7\udc84\u22a5\udc95\udc88\u981d\u553e\udcae\udc8a)\nconst int8_t ENC_TABLE[4][4] = {\n//  \udce6\udc96\udcb0: 00  01  10  11\n    {  0, +1, -1,  0 }, // \udce8\udc88\udc8a 00\n    { -1,  0,  0, +1 }, // \udce8\udc88\udc8a 01\n    { +1,  0,  0, -1 }, // \udce8\udc88\udc8a 10\n    {  0, -1, +1,  0 }, // \udce8\udc88\udc8a 11\n};\n\n// --- 5. LED ---\nvoid setLeds(bool r1, bool g1, bool b1, bool r2, bool g2, bool b2) {\n  bool v[6] = {r1, g1, b1, r2, g2, b2};\n  for (int i = 0; i < 6; i++) digitalWrite(LED_PINS[i], v[i] ? LOW : HIGH);\n}\n\nvoid applyState(char cmd) {\n  switch (cmd) {\n    case 'T': setLeds(0,0,1, 0,0,1); break; // Blue  (Thinking)\n    case 'C': setLeds(0,1,0, 0,1,0); break; // Green (Completed)\n    case 'E': setLeds(1,0,0, 1,0,0); break; // Red   (Error)\n    case 'I': setLeds(0,1,0, 0,1,0); break; // Green (Idle)\n  }\n}\n\n// --- 6. Setup ---\nvoid setup() {\n  for (int i = 0; i < 6; i++) { pinMode(LED_PINS[i], OUTPUT); digitalWrite(LED_PINS[i], HIGH); }\n\n  for (int i = 0; i < 10; i++) {\n    pinMode(BTN_PINS[i], INPUT_PULLUP);\n    rawBtn[i]    = HIGH;\n    stableBtn[i] = HIGH;\n    debounceTimer[i] = 0;\n  }\n\n  pinMode(ENC_CLK, INPUT_PULLUP);\n  pinMode(ENC_DT,  INPUT_PULLUP);\n  encState = encPending = (digitalRead(ENC_CLK) << 1) | digitalRead(ENC_DT);\n\n  Keyboard.begin();\n  Serial.begin(9600);\n\n  // \u8751\udc89\u657a\udc85 USB \udce6\udc9e\udc9a\udce8\udc88\udc89\u6470\udc8c\udce6\udc88\udc90\u5697\udc88\udce6\udc9c\udc80\u61ad\udc9a 2 \u8758\udc92\u5697\udc89\u5697\udc8c\u8763\u7b94\udcbf\udc9d\udce5\udc8b\udc95\udce7\udc95\u6020\udc9c\udca8 USB \u875b\u62d9\udcae\udc9a\u657a\udc8c\udce5\udc9f\u7441\udca1\udc8c\n  unsigned long t0 = millis();\n  while (!TinyUSBDevice.mounted() && (millis() - t0 < 2000)) delay(1);\n\n  // \udce5\udc95\udc9f\udce5\udc8b\udc95\udce6\udc88\udc90\udce5\udc8a\udc9f\udce7\udc9a\udc84\u95ac\udc96\u95ac\u7b8f\udc8f\udc8d\u64d6\udc8b\u5697\udc9a\udce9\udc96\udc83\udce7\udc88\udc8d\u929d\udc89\u7508\u221f\udc97\udc8d\udce7\udc87\udc88\u5697\udc88250ms \udce9\udc80\u671b\udc9c\udc9f\u5697\udc8c\udce8\udc82\udc89\udce7\udc9c\u6f6d\udcb8\udc85\udce6\udc99\u5563\udc8f\u822a\udca6\udc8b\u5697\udc89\n  for (int i = 0; i < 3; i++) {\n    setLeds(0,0,1, 0,0,1); delay(250);\n    setLeds(0,0,0, 0,0,0); delay(250);\n  }\n  applyState('I');\n}\n\n// --- 7. Loop ---\nvoid loop() {\n  unsigned long now = millis();\n\n  // \udce8\udc99\udc95\udce7\udc90\udc86\u6468\udc8f\udce5\udc88\udc97\udce5\udc9f\udca0\udce6\udc8c\udc87\u969e\u4e48n  if (Serial.available()) {\n    char cmd = (char)Serial.read();\n    applyState(cmd);\n  }\n\n  // \udce8\udc99\udc95\udce7\udc90\udc86\udce6\udc8c\udc89\udce9\udc88\udc95\u5697\udc88\udce6\udc99\udc82\udce9\udc96\udc93\udce5\udc9f\u7b87\udca4\udc8e debounce\u5697\udc89\n  for (int i = 0; i < 10; i++) {\n    bool raw = digitalRead(BTN_PINS[i]);\n\n    // \udce5\udc81\u83dc\u846b\udce5\udc88\u5708\udc9b\u98b1\udcbd\udc8d\u9708\udc8a\udce5\udc8c\udc96\u5697\udc8c\udce9\udc87\udc8d\u95ae\u525b\udca8\udc88\udce6\udc99\udc82\udce5\udc99\u6c94n    if (raw != rawBtn[i]) {\n      rawBtn[i] = raw;\n      debounceTimer[i] = now;\n    }\n\n    // \u981e\udc85\udce9\udc81\udc8e\u875b\u62d9\udcae\udc9a\udce6\udc99\udc82\udce9\udc96\udc93\u657a\udc8c\u5697\udc8c\udce6\udc9b\u6e54\udc96\u5541\u5e18\u6470\udc9a\udce7\udc8b\udc80\udce6\udc85\udc8b\u929d\u897f\u5b5b\udce7\udc99\u6f86\udc8b\udc95\u96ff\udc9c\n    if ((now - debounceTimer[i]) >= DEBOUNCE_MS && raw != stableBtn[i]) {\n      stableBtn[i] = raw;\n      if (raw == LOW) {                    // \udce6\udc8c\udc89\u929d\udc8b\n        Keyboard.sendCombo(BTN_KEYS[i]);\n      } else {                             // \udce6\udc94\u66b8\udc96\udc8b\n        Keyboard.releaseAll();\n      }\n    }\n  }\n\n  // \udce8\udc99\udc95\udce7\udc90\udc86\udce6\udc97\udc8b\udce9\udc88\udc95\u5697\udc88\u7507\udca3\u922d\u65a4\udc8b\udc80\udce6\udc85\udc8b\u7488\udc9f + \u875b\u62d9\udcae\udc9a\udce6\udc99\udc82\udce9\udc96\udc93 debounce\u5697\udc89\n  uint8_t rawEnc = (digitalRead(ENC_CLK) << 1) | digitalRead(ENC_DT);\n\n  if (rawEnc != encState) {\n    if (rawEnc != encPending) {\n      encPending = rawEnc;\n      encStableTimer = now;\n    }\n\n    if ((now - encStableTimer) >= ENC_STABLE_MS) {\n      int8_t movement = ENC_TABLE[encState][encPending];\n      if (movement != 0) {\n        encCount += movement;\n      }\n      encState = encPending;\n\n      if (encCount >= STEPS_PER_DETENT) {\n        uint8_t up[3] = {KEY_UP_ARROW, 0, 0};\n        Keyboard.sendCombo(up);\n        Keyboard.releaseAll();\n        encCount = 0;\n      } else if (encCount <= -STEPS_PER_DETENT) {\n        uint8_t dn[3] = {KEY_DOWN_ARROW, 0, 0};\n        Keyboard.sendCombo(dn);\n        Keyboard.releaseAll();\n        encCount = 0;\n      }\n    }\n  }\n}\n", "structuredPatch": [{"oldStart": 61, "oldLines": 16, "newStart": 61, "newLines": 16, "lines": [" ", " //for test", " const uint8_t BTN_KEYS[10][3] = {", "-  {1,  0,           0}, // GP0: Ctrl+C", "-  {2, 0,       0}, // GP1: Shift+Tab", "-  {KEY_LEFT_CTRL,  'e',           0}, // GP2: Ctrl+E", "-  {KEY_UP_ARROW,   0,             0}, // GP3: Up", "-  {KEY_RETURN,     0,             0}, // GP4: Enter", "-  {KEY_LEFT_CTRL,  't',           0}, // GP5: Ctrl+T", "-  {HID_KEY_SLASH,  0,             0}, // GP6: /", "-  {KEY_DOWN_ARROW, 0,             0}, // GP7: Down", "-  {KEY_LEFT_GUI,   KEY_TAB,       0}, // GP8: Win+Tab", "-  {KEY_ESC,        0,             0}  // GP9: ESC", "+  {HID_KEY_0, 0, 0}, // GP0: 0", "+  {HID_KEY_1, 0, 0}, // GP1: 1", "+  {HID_KEY_2, 0, 0}, // GP2: 2", "+  {HID_KEY_3, 0, 0}, // GP3: 3", "+  {HID_KEY_4, 0, 0}, // GP4: 4", "+  {HID_KEY_5, 0, 0}, // GP5: 5", "+  {HID_KEY_6, 0, 0}, // GP6: 6", "+  {HID_KEY_7, 0, 0}, // GP7: 7", "+  {HID_KEY_8, 0, 0}, // GP8: 8", "+  {HID_KEY_9, 0, 0}, // GP9: 9", " };", " /* const uint8_t BTN_KEYS[10][3] = {", "   {KEY_LEFT_CTRL,  'c',           0}, // GP0: Ctrl+C"]}], "userModified": false, "replaceAll": false}, "tool_use_id": "toolu_01TVWKniDcnymKHp4YETSosJ"}
