0\n//\n// \udce3\udc80\udc90BTN_KEYS\udce3\udc80\udc91  \udce5\udc96\u683c\u6d3b\u876f\udc84\udce5\udc90\udc88\udce9\udc8d\u86db\udcbc\udc8c\u9758\udc8b\u6192\udc82 Ctrl+C\udce3\udc80\udc81Win+Tab\n// \udce3\udc80\udc90BTN_MACROS\udce3\udc80\udc91\udce6\udc96\udc87\u646e\udc97\u648c\u5238\udc9b\udc86\u5697\udc8c\udce9\udc80\udc90\u646e\udc97\u981b\u8a68\udc87\u7b94\udcb8\udc80\u929d\u8123\udcad\udc97\udce5\udc85\udc83\n//   - \udce8\udc8b\udca5 BTN_MACROS[i] \udce9\udc9d\udc9e\u875b\u7dbd\udcbc\udc8c\udce5\udc84\u82b8\udc85\udc88\udce5\udc9f\u7441\udca1\udc8c\u648c\u5238\udc9b\udc86\u5697\udc8c\u6579\u8cdc\udc95\udca5 BTN_KEYS[i]\n//   - \udce6\udc94\u8200\udc8f\u6e38\udcad\udc97\udce5\udc85\udc83\u5697\udc9aa-z A-Z 0-9 / \u875b\u7b87\udc99\udcbd Enter(\\n) \u769c\udc9b\udce8\udc99\udc9f(-)\n//   - \u876d\udc84\u9758\udc8b\u5697\udc9a\"/compact\\n\" \u981b\u8a68\udc87\udcba /compact \u657a\udc8c\udce8\udc87\u82b8\udc8b\udc95\udce6\udc8c\udc89 Enter,\u96ff\udc86\u6192\udc82\udce6\udc9e\udc9c\u96ff\udca0\udce6\udc98\u81ed\u8449\udce6\udc96\udc87\u981b\u8a68\udc85\u4ea4\udcb3\udc95\u96ff\u8f3b\udc94\u523b\udc80\udc85\u5697\udc8c\u64b1\u7b84\u964d\u61ad\udc9a\udce5\udc8a\udca0\u929d\udc80\udce5\udc80\udc8b\udce2\udc80\udc9c\\n\udce2\udc80\udc9d\u9708\udc8a\udce6\udc88\udc90\"/compact\\n\\n\"\udce5\udc9b\udca0\udce7\udc88\u8130\u6493\udce5\udc85\u4ea4\udcb3\udc95\udce6\udc9c\udc83\udce5\udc90\udc83\udce6\udc8e\udc89\u929d\udc80\udce5\udc80\udc8b\"\\n\"\n\nconst char* BTN_MACROS[10] = {\n  \"/compact\\n\\n\",             // [0] \n  \"\",             // [1] \n  \"\",             // [2] \n  \"\",             // [3] \n  \"/gitPush\\n\\n\",             // [4] \n  \"claude\\n\\n\",             // [5] \n  \"/clear\\n\\n\",             // [6] \n  \"/compact\\n\\n\",             // [7] \n  \"\",             // [8] \n  \"\",             // [9] \n};\n\nconst uint8_t BTN_KEYS[10][3] = {\n  {SLASH,    0, 0  },  // [0] \n  {SHIFT, TAB, 0},  // [1] \n  {DEL, TAB, 0},  // [2] \n  {ENTER, 0, 0},  // [3] \n  {0, 0, 0},  // [4] \n  {0, 0, 0},  // [5] \n  {0, 0, 0},  // [6] \n  {0, 0, 0},  // [7]            \n  {CTL, L('c'), 0},  // [8] Terminate \udce2\udc86\udc92 Ctrl+c\n  {ESC, 0, 0},  // [9] \udce6\udc97\udc8b\udce9\udc88\udc95\udce6\udc8c\udc89\u929d\udc8b \udce2\udc86\udc92 ESC\n};\n", "numLines": 104, "startLine": 1, "totalLines": 104}}, "tool_use_id": "toolu_012UaavXuqu4UmGVAPEQQEcW"}
